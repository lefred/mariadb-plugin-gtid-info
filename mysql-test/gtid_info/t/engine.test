--source include/have_innodb.inc
--source include/have_log_bin.inc
--source include/have_binlog_format_row.inc

SELECT LCASE(@@global.binlog_storage_engine) = 'innodb'
       AS using_innodb_binlog;

CREATE TABLE engine_t (a INT PRIMARY KEY, b VARCHAR(20));
INSERT INTO engine_t VALUES (1, 'anchor');
SET @anchor= @@last_gtid;
FLUSH NO_WRITE_TO_BINLOG BINARY LOGS;
INSERT INTO engine_t VALUES (2, 'undo');
SET @latest= @@last_gtid;

SET @anchor_info= GTID_INFO(@anchor);
SET @latest_info= GTID_INFO(@latest);
SET @anchor_log= JSON_VALUE(@anchor_info, '$.binlog');
SET @latest_log= JSON_VALUE(@latest_info, '$.binlog');

SELECT JSON_VALUE(@anchor_info, '$.present') = 1
       AS engine_gtid_info_present;
SELECT @anchor_log <> @latest_log AS engine_rotation_visible;
SELECT LOCATE(@latest, BINLOG_GTID_LIST(@latest_log)) > 0
       AS engine_binlog_gtid_list;
SELECT BINLOG_GTID_LIST_GAPS(@latest_log) = ''
       AS engine_binlog_gtid_gaps;
SELECT LOCATE(@latest, BINLOG_GTID_LIST_RANGES(@latest_log)) > 0
       AS engine_binlog_gtid_ranges;
SELECT JSON_LENGTH(GTID_LIST_BINLOGS(CONCAT(@anchor, ',', @latest))) = 2
       AS engine_gtid_list_binlogs;

SET @commit_time=
  FROM_UNIXTIME(CAST(JSON_VALUE(@latest_info, '$.commit_timestamp')
                     AS UNSIGNED));
SELECT LOCATE(@latest, GTID_AT(@commit_time)) > 0 AS engine_gtid_at;

SET @flashback= GTID_FLASHBACK(@latest);
SELECT LOCATE('DELETE FROM `test`.`engine_t` WHERE `a` <=> 2',
              @flashback) > 0 AS engine_gtid_flashback;
SET @flashback_to= GTID_FLASHBACK_TO(@anchor);
SELECT LOCATE('DELETE FROM `test`.`engine_t` WHERE `a` <=> 2',
              @flashback_to) > 0 AS engine_gtid_flashback_to;

DROP TABLE engine_t;
